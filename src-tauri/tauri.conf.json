{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RainySteamRecord",
  "version": "0.2.1",
  "identifier": "com.catmiaozhi.rainysteamrecord",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RainySteamRecord",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/ffmpeg.exe",
      "binaries/mpv.exe",
      "binaries/d3dcompiler_43.dll"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"]
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "plugins": {}
}
