{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.catmiaozhi.rainysteamrecord",
  "description": "File system and dialog access for RainySteamRecord",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging"
  ]
}
